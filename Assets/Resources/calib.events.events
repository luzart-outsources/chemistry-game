                    "comparison": {
                        "operator": "gt",
                        "value": 0
                    }
                },
                "currency": {
                    "option": "required",
                    "field_type": "string",
                    "valid_values": [
                        "USD"
                    ]
                },
                "order_id": {
                    "option": "required",
                    "field_type": "string"
                },
                "order_type": {
                    "option": "required",
                    "field_type": "string",
                    "valid_values": [
                        "SUB"
                    ]
                },
                "trans_ts": {
                    "option": "required",
                    "field_type": "timestamp"
                },
                "sandbox": {
                    "option": "required",
                    "field_type": "string",
                    "valid_values": [
                        "true",
                        "false"
                    ]
                },
                "tracking_source": {
                    "option": "required",
                    "field_type": "string",
                    "valid_values": [
                        "sever"
                    ]
                },
                "is_renew": {
                    "option": "required",
                    "field_type": "int",
                    "valid_values": [
                        "0",
                        "1"
                    ]
                }
            },
            "tch_ad_rev_roas_001": {
                "ad_platform": {
                    "option": "required",
                    "field_type": "string",
                    "valid_values": [
                        "google_play",
                        "appstore",
                        "thirdparty",
                        "MAX",
                        "ADMOB",
                        "IRONSOURCE",
                        "FUSION"
                    ]
                },
                "value": {
                    "option": "required",
