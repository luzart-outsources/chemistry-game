{
    "gurusdk": "v3.2.1",
    "event_rules": {
        "explicit": {
            "level_start": {
                "item_category": {
                    "option": "required",
                    "field_type": "string",
                    "valid_values": [
                        "main",
                        "daily"
                    ]
                },
                "level_name": {
                    "option": "required",
                    "field_type": "string"
                },
                "level": {
                    "option": "required",
                    "field_type": "int",
                    "comparison": {
                        "operator": "ge",
                        "value": 1
                    }
                },
                "start_type": {
                    "option": "required",
                    "field_type": "string",
                    "valid_values": [
                        "play",
                        "continue",
                        "replay"
                    ]
                },
                "play_count": {
                    "option": "required",
                    "field_type": "int",
                    "comparison": {
                        "operator": "ge",
                        "value": 1
                    }
                },
                "item_id": {
                    "option": "conditional",
                    "field_type": "date"
                }
            },
            "level_end": {
                "item_category": {
                    "option": "required",
                    "field_type": "string",
                    "valid_values": [
                        "main",
                        "daily"
                    ]
                },
                "level_name": {
                    "option": "required",
                    "field_type": "string"
                },
                "level": {
                    "option": "required",
                    "field_type": "int",
                    "comparison": {
                        "operator": "ge",
                        "value": 1
                    }
                },
                "result": {
                    "option": "required",
                    "field_type": "string",
                    "valid_values": [
                        "success",
                        "fail",
                        "exit"
                    ]
                },
                "duration": {
                    "option": "required",
                    "field_type": "int",
                    "comparison": {
                        "operator": "gt",
                        "value": 0
                    }
                },
                "level_duration": {
                    "option": "required",
                    "field_type": "int",
                    "comparison": {
                        "operator": "gt",
                        "value": 0
                    }
                },
                "revive": {
                    "option": "required",
                    "field_type": "int",
                    "comparison": {
                        "operator": "ge",
                        "value": 0
                    }
                },
                "item_id": {
                    "option": "conditional",
                    "field_type": "date"
                },
                "step": {
                    "option": "conditional",
                    "field_type": "int",
                    "comparison": {
                        "operator": "gt",
                        "value": 0
                    }
                },
                "score": {
                    "option": "conditional",
                    "field_type": "int",
                    "comparison": {
                        "operator": "ge",
                        "value": 0
                    }
                },
                "stage": {
                    "option": "conditional",
                    "field_type": "int",
                    "comparison": {
                        "operator": "ge",
                        "value": 1
                    }
                }
            },
            "earn_virtual_currency": {
                "virtual_currency_name": {
                    "option": "required",
                    "field_type": "string",
                    "valid_values": [
                        "coin"
                    ]
                },
                "item_category": {
                    "option": "required",
                    "field_type": "string",
                    "valid_values": [
                        "iap_buy"
                    ]
                },
                "level_name": {
                    "option": "required",
                    "field_type": "string"
                },
                "value": {
                    "option": "required",
                    "field_type": "int",
                    "comparison": {
                        "operator": "gt",
                        "value": 0
                    }
                },
                "balance": {
                    "option": "required",
                    "field_type": "int",
                    "comparison": {
                        "operator": "ge",
                        "value": 0
                    }
                },
                "item_name": {
                    "option": "optional",
                    "field_type": "string"
                },
                "scene": {
                    "option": "optional",
                    "field_type": "string"
                },
                "stage": {
                    "option": "optional",
                    "field_type": "int",
                    "comparison": {
                        "operator": "ge",
                        "value": 0
                    }
                }
            },
            "spend_virtual_currency": {
                "virtual_currency_name": {
                    "option": "required",
                    "field_type": "string",
                    "valid_values": [
                        "coin"
                    ]
                },
                "item_category": {
                    "option": "required",
                    "field_type": "string"
                },
                "level_name": {
                    "option": "required",
                    "field_type": "string"
                },
                "value": {
                    "option": "required",
                    "field_type": "int",
                    "comparison": {
                        "operator": "gt",
                        "value": 0
                    }
                },
                "balance": {
                    "option": "required",
                    "field_type": "int",
                    "comparison": {
                        "operator": "ge",
                        "value": 0
                    }
                },
                "item_name": {
                    "option": "optional",
                    "field_type": "string"
                },
                "scene": {
                    "option": "optional",
                    "field_type": "string"
                },
                "stage": {
                    "option": "optional",
                    "field_type": "int",
                    "comparison": {
                        "operator": "ge",
                        "value": 0
                    }
                }
            },
            "level_up": {
                "level": {
                    "option": "required",
                    "field_type": "int",
                    "comparison": {
                        "operator": "gt",
                        "value": 0
                    }
                },
                "character": {
                    "option": "conditional",
                    "field_type": "string"
                }
            },
            "unlock_achievement": {
                "achievement_id": {
                    "option": "conditional",
                    "field_type": "string"
                }
            },
            "hp_points": {
                "change_type": {
                    "option": "required",
                    "field_type": "string",
                    "valid_values": [
                        "spend",
                        "earn"
                    ]
                },
                "item_category": {
                    "option": "required",
                    "field_type": "string"
                },
                "item_name": {
                    "option": "required",
                    "field_type": "string",
                    "valid_values": [
                        "coin",
                        "rads"
                    ]
                },
                "before": {
                    "option": "required",
                    "field_type": "int",
                    "comparison": {
                        "operator": "ge",
                        "value": 0
                    }
                },
                "num": {
                    "option": "required",
                    "field_type": "int"
                },
                "after": {
                    "option": "required",
                    "field_type": "int",
                    "comparison": {
                        "operator": "ge",
                        "value": 0
                    }
                }
            },
            "iap_imp": {
                "item_category": {
                    "option": "required",
                    "field_type": "string"
                }
            },
            "iap_clk": {
                "item_category": {
                    "option": "required",
                    "field_type": "string"
                },
                "product_id": {
                    "option": "required",
                    "field_type": "string",
                    "pattern": "^[^:]+(?::[^:]+(?::[^:]+)?)?$"
                }
            },
            "iap_close": {
                "item_category": {
                    "option": "required",
                    "field_type": "string"
                }
            },
            "iap_ret_true": {
                "item_category": {
                    "option": "required",
                    "field_type": "string"
                },
                "item_name": {
                    "option": "required",
                    "field_type": "string"
                },
                "product_id": {
                    "option": "required",
                    "field_type": "string"
                },
                "value": {
                    "option": "required",
                    "field_type": "double",
                    "comparison": {
                        "operator": "ge",
                        "value": 0
                    }
                },
                "currency": {
                    "option": "required",
                    "field_type": "string"
                },
                "order_id": {
                    "option": "required",
                    "field_type": "string"
                },
                "type": {
                    "option": "required",
                    "field_type": "string",
                    "valid_values": [
                        "subscription",
                        "product"
                    ]
                },
                "isfree": {
                    "option": "required",
                    "field_type": "string",
                    "valid_values": [
                        "1",
                        "0"
                    ]
                }
            },
            "iap_ret_false": {
                "item_category": {
                    "option": "required",
                    "field_type": "string"
                },
                "item_name": {
                    "option": "required",
                    "field_type": "string"
                },
                "product_id": {
                    "option": "required",
                    "field_type": "string"
                },
                "reason": {
                    "option": "required",
                    "field_type": "string",
                    "valid_values": [
                        "cancel"
                    ]
                }
            },
            "iap_purchase": {
                "platform": {
                    "option": "required",
                    "field_type": "string",
                    "valid_values": [
                        "google_play",
                        "appstore",
                        "thirdparty"
                    ]
                },
                "product_id": {
                    "option": "required",
                    "field_type": "string"
                },
                "value": {
                    "option": "required",
                    "field_type": "double",
                    "comparison": {
                        "operator": "gt",
                        "value": 0
                    }
                },
                "currency": {
                    "option": "required",
                    "field_type": "string",
                    "valid_values": [
                        "USD"
                    ]
                },
                "order_id": {
                    "option": "required",
                    "field_type": "string"
                },
                "order_type": {
                    "option": "required",
                    "field_type": "string",
                    "valid_values": [
                        "IAP"
                    ]
                },
                "trans_ts": {
                    "option": "required",
                    "field_type": "timestamp"
                },
                "sandbox": {
                    "option": "required",
                    "field_type": "string",
                    "valid_values": [
                        "true",
                        "false"
                    ]
                }
            },
            "sub_purchase": {
                "platform": {
                    "option": "required",
                    "field_type": "string",
